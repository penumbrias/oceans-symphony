<?xml version="1.0" encoding="utf-8"?>
<!--
  Single home-screen shortcut that opens the existing in-app "Quick
  Actions" overlay (the menu users get from long-pressing the Quick
  Check-In button on the Dashboard). Instead of replicating that
  menu's items at the OS level (which would (a) duplicate the user's
  own customised list from QuickActionsConfig, and (b) not respect
  the user's term overrides — OS labels are static), we surface one
  entry point that drops the user straight into the same menu they
  already know.

  Flow: launcher long-press → "Quick Actions" tap → MainActivity opens
  with VIEW intent at https://app.local.oceans-symphony/?openQuickActions=1
  → Capacitor's BridgeActivity routes the URL into the WebView → the
  Dashboard's mount-time effect reads the query param and triggers
  setShowQuickActions(true).
-->
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
  <shortcut
      android:shortcutId="quick_actions"
      android:enabled="true"
      android:icon="@drawable/ic_shortcut_quick_actions"
      android:shortcutShortLabel="@string/shortcut_quick_actions_short"
      android:shortcutLongLabel="@string/shortcut_quick_actions_long">
    <intent
        android:action="android.intent.action.VIEW"
        android:targetPackage="app.oceans_symphony.nativeapp"
        android:targetClass="app.oceans_symphony.nativeapp.MainActivity"
        android:data="https://app.local.oceans-symphony/?openQuickActions=1" />
    <categories android:name="android.shortcut.conversation" />
  </shortcut>
</shortcuts>
