<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <!-- android:statusBarColor and android:navigationBarColor are
         deprecated as of Android 15 (API 35). Edge-to-edge handling
         lives in MainActivity.java via EdgeToEdge.enable(), which
         covers backward-compat down to older Android versions too. -->
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
    </style>


    <!-- The launch theme: an androidx.core.splashscreen splash that
         draws the splash drawable across the window background.
         CRITICAL: postSplashScreenTheme tells the splash library which
         theme to swap to once the splash dismisses. Without it (and
         without an installSplashScreen() call in MainActivity), the
         splash drawable + the system-rendered splash branding stay on
         screen behind the WebView. When EdgeToEdge.enable() was added
         in 0.17.24 the WebView no longer covers the area between the
         status bar and the content, so the persistent splash icon /
         label became visible as a phantom band above the AppLayout
         header on every page — see PR fixing the duplicate-header bug.
         windowActionBar / windowNoTitle are belt-and-braces in case
         Theme.SplashScreen's parent ever changes to one that keeps the
         action bar around. -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@drawable/splash</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>
</resources>
