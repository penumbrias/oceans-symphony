<?xml version="1.0" encoding="utf-8" ?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android" xmlns:tools="http://schemas.android.com/tools">
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- No static shortcuts — the launcher long-press menu is
                 populated dynamically by QuickActionsPlugin from the
                 user's in-app QuickAction list. See
                 src/lib/nativeQuickActions.js. -->
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data android:name="android.support.FILE_PROVIDER_PATHS" android:resource="@xml/file_paths" />
        </provider>

        <!-- Default channel for FCM "notification" messages. When a cloud
             push arrives while the app is backgrounded, the system posts it;
             if the payload's channel isn't found (or none is set) FCM falls
             back to THIS channel instead of a generic, silent "Miscellaneous"
             one. Must match REMINDERS_CHANNEL_ID in
             src/lib/nativeNotifications.js (the high-importance, vibrating
             "Reminders" channel the app creates on launch) so reminder pushes
             actually buzz. -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="reminders-default-v2" />

        <!-- Status-bar icon for FCM "notification" messages so cloud
             reminders show the same branded glyph as on-device local
             notifications (capacitor.config LocalNotifications.smallIcon),
             instead of the masked-to-white launcher icon. Must be a flat
             silhouette drawable (res/drawable/ic_stat_symphony.xml). -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_stat_symphony" />
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Legacy storage write — only requested on Android 9 and below.
         Android 10+ uses MediaStore.Downloads (handled by
         MediaStoreSavePlugin) and doesn't require this permission.
         maxSdkVersion="28" stops the request flow on modern Android
         so users don't see a confusing storage-permission prompt
         the app doesn't actually use. -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28" />

    <!-- Foreground location — used by the "Log location" feature
         (Dashboard quick action, Check-In modal, Location History
         "Get GPS" button). The user actively taps a button to capture
         their current coordinates, which are stored locally as a
         Location record. @capacitor/geolocation also injects these,
         but listing them here makes the justification explicit.
         -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <!-- Exact alarms — @capacitor/local-notifications hands scheduled
         reminders to AlarmManager. WITHOUT exact-alarm permission Android
         uses INEXACT alarms, which Samsung One UI defers or drops outright
         when the app is closed — that's the root of the "reminders never
         reach the tray" reports. Timed reminders are a core app feature, so
         exact alarms are justified (the Play Console "Alarms & reminders" /
         "Use exact alarm" declaration).
           • SCHEDULE_EXACT_ALARM is auto-granted through API 32. Capped at 32
             (tools:replace overrides background-runner's unbounded copy) so it
             doesn't trip the user-grant flow on newer Android.
           • USE_EXACT_ALARM covers API 33+ — auto-granted, no prompt.
         background-runner only declared SCHEDULE_EXACT_ALARM defensively; the
         app now actually uses exact alarms, so it's no longer stripped. -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" android:maxSdkVersion="32" tools:replace="android:maxSdkVersion" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <!-- Background location stays stripped — background-runner declares it
         defensively but the app never uses it. -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" tools:node="remove" />
</manifest>
