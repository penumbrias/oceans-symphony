{
  "name": "SymptomCheckIn",
  "type": "object",
  "properties": {
    "symptom_id": {
      "type": "string",
      "description": "References Symptom.id"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When this check-in was recorded"
    },
    "severity": {
      "type": "number",
      "description": "Optional severity 0-5, null if not set (boolean symptoms have no severity)"
    },
    "check_in_id": {
      "type": "string",
      "description": "Optional reference to parent EmotionCheckIn"
    }
  },
  "required": [
    "symptom_id",
    "timestamp"
  ],
  "rls": {
    "create": {
      "created_by": "{{user.email}}"
    },
    "read": {
      "created_by": "{{user.email}}"
    },
    "update": {
      "created_by": "{{user.email}}"
    },
    "delete": {
      "created_by": "{{user.email}}"
    }
  }
}